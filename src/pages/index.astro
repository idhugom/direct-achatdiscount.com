---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { byDateDesc } from '../lib/articles';
import { CATEGORIES } from '../lib/categories';
import { SITE } from '../lib/site';

const all = (await getCollection('articles')).sort(byDateDesc);
const featured = all.filter((a) => a.data.featured);
const cover = featured[0] || all[0];
const topRow = (featured.length >= 3 ? featured : all).slice(0, 3);
const latest = all.filter((a) => a !== cover && !topRow.includes(a)).slice(0, 9);

// compte par rubrique
const counts = new Map<string, number>();
for (const a of all) counts.set(a.data.category, (counts.get(a.data.category) || 0) + 1);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/recherche/?q={query}`,
    'query-input': 'required name=query',
  },
};
---

<Base jsonLd={jsonLd}>
  <Hero featured={cover} count={all.length} />
  <Ticker />

  {topRow.length > 0 && (
    <section class="section wrap-wide">
      <SectionHeading kicker="La sélection" title="Les guides à ne pas manquer" href="/articles/" accent="var(--pink)" />
      <div class="feat-grid">
        {topRow.map((a, i) => (
          <div class:list={['reveal', i === 0 && 'feat-grid__lead']} data-delay={i}>
            <ArticleCard article={a} size={i === 0 ? 'lg' : 'md'} />
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section wrap-wide">
    <SectionHeading kicker="Explorez" title="Toutes nos rubriques" href="/rubriques/" accent="var(--cyan)" />
    <div class="rubs">
      {CATEGORIES.map((c, i) => (
        <a href={`/rubrique/${c.slug}/`} class="rub reveal" data-delay={(i % 4)} style={`--cat:${c.color};--cat-ink:${c.ink}`}>
          <span class="rub__emoji" aria-hidden="true">{c.emoji}</span>
          <span class="rub__name">{c.short}</span>
          <span class="rub__tag">{c.tagline}</span>
          <span class="rub__count u-mono">{counts.get(c.slug) || 0} article{(counts.get(c.slug) || 0) > 1 ? 's' : ''}</span>
          <span class="rub__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </section>

  {latest.length > 0 && (
    <section class="section wrap-wide">
      <SectionHeading kicker="Frais du jour" title="Les derniers guides" href="/articles/" accent="var(--lime)" />
      <div class="cards-grid">
        {latest.map((a, i) => (
          <div class="reveal" data-delay={(i % 4)}><ArticleCard article={a} /></div>
        ))}
      </div>
    </section>
  )}

  <CtaBand />
</Base>

<style>
  .feat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .feat-grid__lead { grid-column: 1 / -1; }
  @media (max-width: 720px) { .feat-grid { grid-template-columns: 1fr; } }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1.4rem; }

  .rubs { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
  .rub {
    position: relative; display: grid; gap: 0.3rem; padding: 1.3rem 1.3rem 1.4rem;
    background: var(--cat); color: var(--cat-ink);
    border: 2.5px solid var(--ink); border-radius: var(--radius);
    overflow: hidden; transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    min-height: 158px;
  }
  .rub:hover { transform: translate(-4px, -4px); box-shadow: var(--shadow-hard-lg); }
  .rub__emoji { font-size: 2rem; }
  .rub__name { font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; letter-spacing: -0.02em; }
  .rub__tag { font-size: 0.86rem; opacity: 0.82; font-weight: 500; max-width: 22ch; }
  .rub__count { font-size: 0.78rem; font-weight: 700; margin-top: 0.4rem; opacity: 0.85; }
  .rub__arrow { position: absolute; top: 1.1rem; right: 1.2rem; font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; transition: transform 0.3s var(--ease-out); }
  .rub:hover .rub__arrow { transform: translateX(5px); }
</style>
