---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { CATEGORIES, getCategory } from '../../../lib/categories';
import { byDateDesc } from '../../../lib/articles';
import { SITE } from '../../../lib/site';

export async function getStaticPaths() {
  const all = (await getCollection('articles')).sort(byDateDesc);
  return CATEGORIES.map((c) => ({
    params: { cat: c.slug },
    props: { cat: c, articles: all.filter((a) => a.data.category === c.slug) },
  }));
}

const { cat, articles } = Astro.props;
const other = CATEGORIES.filter((c) => c.slug !== cat.slug);
---

<Base
  title={cat.name}
  description={`${cat.name} — ${cat.tagline}. Tous nos guides et conseils sur ${SITE.name}.`}
  accent={cat.color}
  accentInk={cat.ink}
>
  <header class="cathead" style={`--cat:${cat.color};--cat-ink:${cat.ink}`}>
    <div class="cathead__bg" aria-hidden="true"></div>
    <div class="wrap-wide cathead__in">
      <nav class="cathead__crumb"><a href="/">Accueil</a> <span aria-hidden="true">/</span> <a href="/rubriques/">Rubriques</a></nav>
      <div class="cathead__row">
        <span class="cathead__emoji" aria-hidden="true">{cat.emoji}</span>
        <div>
          <h1 class="cathead__title">{cat.name}</h1>
          <p class="cathead__tag">{cat.tagline}</p>
        </div>
      </div>
      <p class="cathead__count u-mono">{articles.length} article{articles.length > 1 ? 's' : ''}</p>
    </div>
  </header>

  <section class="section wrap-wide">
    {articles.length > 0 ? (
      <div class="cards-grid">
        {articles.map((a, i) => (<div class="reveal" data-delay={i % 4}><ArticleCard article={a} index={i} /></div>))}
      </div>
    ) : (
      <div class="empty">
        <p class="empty__emoji" aria-hidden="true">{cat.emoji}</p>
        <h2>Bientôt de nouveaux guides ici</h2>
        <p>Cette rubrique se remplit à mesure que nos guides sont publiés. Revenez très vite&nbsp;!</p>
        <a href="/articles/" class="btn btn--accent">Voir tous les guides →</a>
      </div>
    )}
  </section>

  <section class="section wrap-wide">
    <h2 class="other__h">Explorer d’autres rubriques</h2>
    <div class="other">
      {other.map((c) => (
        <a href={`/rubrique/${c.slug}/`} class="other__pill" style={`--cat:${c.color};--cat-ink:${c.ink}`}>
          <span aria-hidden="true">{c.emoji}</span>{c.short}
        </a>
      ))}
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .cathead { position: relative; overflow: hidden; background: var(--ink); color: var(--paper); border-bottom: 3px solid var(--ink); }
  .cathead__bg { position: absolute; inset: 0; background: radial-gradient(70% 120% at 80% 0%, color-mix(in srgb, var(--cat) 65%, transparent), transparent 65%); opacity: 0.7; }
  .cathead__in { position: relative; z-index: 1; padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .cathead__crumb { font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; color: color-mix(in srgb, var(--paper) 70%, transparent); margin-bottom: 1.4rem; display: flex; gap: 0.5rem; }
  .cathead__crumb a:hover { color: var(--cat); }
  .cathead__row { display: flex; align-items: center; gap: 1.2rem; }
  .cathead__emoji { font-size: clamp(2.6rem, 6vw, 4.5rem); line-height: 1; filter: drop-shadow(3px 3px 0 var(--cat)); }
  .cathead__title { font-size: clamp(2.2rem, 1.4rem + 5vw, 4.5rem); line-height: 0.98; }
  .cathead__tag { color: color-mix(in srgb, var(--paper) 82%, transparent); font-size: clamp(1rem, 0.95rem + 0.5vw, 1.3rem); margin-top: 0.3rem; }
  .cathead__count { margin-top: 1.4rem; display: inline-block; background: var(--cat); color: var(--cat-ink); border: 2.5px solid var(--paper); padding: 0.3em 0.9em; border-radius: 100px; font-weight: 700; font-size: 0.9rem; }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 1.4rem; }

  .empty { text-align: center; padding: 3rem 1rem; border: 3px dashed var(--ink); border-radius: var(--radius-lg); background: var(--paper-2); }
  .empty__emoji { font-size: 4rem; }
  .empty h2 { font-size: 1.8rem; margin: 0.6rem 0; }
  .empty p { max-width: 40ch; margin: 0 auto 1.4rem; color: color-mix(in srgb, var(--ink) 72%, transparent); }

  .other__h { font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2rem); margin-bottom: 1.2rem; }
  .other { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .other__pill { display: inline-flex; align-items: center; gap: 0.4em; padding: 0.6em 1.1em; background: var(--cat); color: var(--cat-ink); border: 2.5px solid var(--ink); border-radius: 100px; font-family: var(--font-display); font-weight: 700; transition: transform 0.2s var(--ease-spring), box-shadow 0.2s; }
  .other__pill:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--ink); }
</style>
