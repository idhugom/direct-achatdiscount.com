---
interface Props { kicker?: string; title: string; href?: string; hrefLabel?: string; accent?: string; }
const { kicker, title, href, hrefLabel = 'Tout voir', accent } = Astro.props;
---
<div class="sh reveal" style={accent ? `--accent:${accent}` : undefined}>
  <div>
    {kicker && <p class="sh__kicker">{kicker}</p>}
    <h2 class="sh__title">{title}</h2>
  </div>
  {href && <a href={href} class="sh__link">{hrefLabel} <span aria-hidden="true">→</span></a>}
</div>
<style>
  .sh { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.8rem; flex-wrap: wrap; }
  .sh__kicker { display: inline-block; font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.78rem; color: var(--ink); background: var(--accent); border: 2px solid var(--ink); padding: 0.25em 0.7em; border-radius: 100px; margin-bottom: 0.7rem; }
  .sh__title { font-size: clamp(1.7rem, 1.2rem + 2.4vw, 3rem); letter-spacing: -0.03em; }
  .sh__link { font-family: var(--font-display); font-weight: 700; white-space: nowrap; padding: 0.5em 1em; border: 2.5px solid var(--ink); border-radius: 100px; transition: transform 0.2s var(--ease-spring), background 0.2s, color 0.2s; }
  .sh__link:hover { background: var(--ink); color: var(--paper); transform: translate(-2px, -2px); box-shadow: 3px 3px 0 var(--accent); }
</style>
