---
import { SITE, NAV } from '../lib/site';
---

<header class="hd" data-header>
  <div class="hd__inner wrap-wide">
    <a href="/" class="hd__brand" aria-label={`${SITE.name} — accueil`}>
      <span class="hd__spark" aria-hidden="true"></span>
      <span class="hd__name">
        <b>Direct</b><i>Achat</i><u>Discount</u>
      </span>
    </a>

    <nav class="hd__nav" data-menu aria-label="Navigation principale">
      {NAV.map((item) => (
        <a href={item.href} class="hd__link">{item.label}</a>
      ))}
      <a href="/recherche/" class="hd__search" aria-label="Rechercher">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <span>Rechercher</span>
      </a>
    </nav>

    <button class="hd__burger" data-menu-toggle aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .hd {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
    border-bottom: 2.5px solid var(--ink);
    transition: transform 0.4s var(--ease-out), background 0.3s;
  }
  .hd.is-scrolled { background: color-mix(in srgb, var(--paper) 94%, transparent); }
  .hd.is-hidden { transform: translateY(-100%); }

  .hd__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 68px;
  }

  .hd__brand { display: inline-flex; align-items: center; gap: 0.6rem; }
  .hd__spark {
    width: 26px; height: 26px; border-radius: 8px;
    background: conic-gradient(from 0deg, var(--pink), var(--orange), var(--lime), var(--cyan), var(--violet), var(--pink));
    border: 2.5px solid var(--ink);
    animation: spin-slow 9s linear infinite;
    flex: none;
  }
  .hd__name {
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    font-size: 1.28rem;
    line-height: 1;
    display: inline-flex;
    gap: 0.12em;
  }
  .hd__name b { font-style: normal; }
  .hd__name i { font-style: normal; color: var(--pink); }
  .hd__name u { text-decoration: none; color: var(--violet); }

  .hd__nav { display: flex; align-items: center; gap: 0.35rem; }
  .hd__link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    padding: 0.4em 0.7em;
    border-radius: 100px;
    transition: background 0.2s, color 0.2s;
  }
  .hd__link:hover { background: var(--ink); color: var(--paper); }

  .hd__search {
    display: inline-flex; align-items: center; gap: 0.4em;
    margin-left: 0.4rem; padding: 0.5em 1em;
    background: var(--lime); color: var(--ink);
    border: 2.5px solid var(--ink); border-radius: 100px;
    font-family: var(--font-display); font-weight: 700; font-size: 0.9rem;
    transition: transform 0.2s var(--ease-spring);
  }
  .hd__search:hover { transform: translate(-2px, -2px); box-shadow: 3px 3px 0 var(--ink); }

  .hd__burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; padding: 8px; }
  .hd__burger span { width: 26px; height: 3px; background: var(--ink); border-radius: 3px; transition: transform 0.3s var(--ease-out), opacity 0.2s; }

  @media (max-width: 940px) {
    .hd__search span { display: none; }
    .hd__burger { display: flex; }
    .hd__nav {
      position: fixed; inset: 68px 0 auto 0;
      flex-direction: column; align-items: stretch; gap: 0.2rem;
      background: var(--paper); border-bottom: 2.5px solid var(--ink);
      padding: 1rem var(--gutter) 1.6rem;
      transform: translateY(-120%);
      transition: transform 0.4s var(--ease-out);
      max-height: calc(100dvh - 68px); overflow-y: auto;
    }
    :global(body.menu-open) .hd__nav { transform: none; }
    .hd__link { font-size: 1.3rem; padding: 0.6em 0.5em; border-bottom: 1px dashed var(--paper-3); border-radius: 0; }
    .hd__search { margin: 0.6rem 0 0; justify-content: center; }
    .hd__search span { display: inline; }
    :global(body.menu-open) .hd__burger span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    :global(body.menu-open) .hd__burger span:nth-child(2) { opacity: 0; }
    :global(body.menu-open) .hd__burger span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }
</style>
